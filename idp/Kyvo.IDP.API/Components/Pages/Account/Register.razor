@page "/account/register"
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<HeadContent>
    <title>Criar conta - Kyvo IDP</title>
</HeadContent>

<div class="account-page">
    <header class="account-header">
        <p class="account-brand">Kyvo</p>
        <h1>Criar conta</h1>
        <p class="account-subtitle">Registre-se com e-mail e senha.</p>
    </header>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="account-alert" role="alert">@ResolveError(Error)</div>
    }

    <form method="post" action="/account/register" class="account-form" novalidate>
        <input type="hidden" name="__RequestVerificationToken" value="@_antiforgeryToken" />
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />

        <div class="account-field">
            <label for="displayName">Nome</label>
            <input id="displayName" type="text" name="displayName" autocomplete="name" required placeholder="Seu nome" />
        </div>

        <div class="account-field">
            <label for="email">E-mail</label>
            <input id="email" type="email" name="email" autocomplete="username" required placeholder="voce@empresa.com" />
        </div>

        <div class="account-field">
            <label for="password">Senha</label>
            <input id="password" type="password" name="password" autocomplete="new-password" required minlength="8" />
        </div>

        <div class="account-field">
            <label for="passwordConfirm">Confirmar senha</label>
            <input id="passwordConfirm" type="password" name="passwordConfirm" autocomplete="new-password" required minlength="8" />
        </div>

        <button type="submit" class="account-btn account-btn-primary">Criar conta</button>
    </form>

    <footer class="account-footer">
        <span>Já tem uma conta?</span>
        <a href="@($"/account/login?returnUrl={Uri.EscapeDataString(ReturnUrl ?? string.Empty)}")">Entrar</a>
    </footer>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string _antiforgeryToken = string.Empty;

    protected override void OnInitialized()
    {
        var httpContext = HttpContextAccessor.HttpContext
            ?? throw new InvalidOperationException("HTTP context is not available.");
        _antiforgeryToken = Antiforgery.GetAndStoreTokens(httpContext).RequestToken ?? string.Empty;
    }

    private static string ResolveError(string code) => code switch
    {
        "password_mismatch" => "As senhas não coincidem.",
        "email_exists" => "Já existe uma conta com este e-mail.",
        "validation" => "Preencha todos os campos corretamente.",
        "session_expired" => "Sessão expirada. Tente novamente.",
        _ => "Não foi possível criar a conta."
    };
}
