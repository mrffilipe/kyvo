# Admin SPA — local development (npm run dev or frontend/docker-compose.yml)
#
# Setup:
#   cp .env.example .env
#
# All variables below are optional; the same values are baked into src/config/env.ts when unset.

# Docker Compose only (frontend/docker-compose.yml)
FRONTEND_PORT=3000

VITE_API_BASE_URL=http://localhost:5000
VITE_API_VERSION=1.0
VITE_API_TIMEOUT_MS=30000
VITE_OAUTH_CLIENT_ID=platform-admin-web
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
