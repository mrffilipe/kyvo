{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=kyvo_db;Username=postgres;Password=postgrespassword"
  },

  "Jwt": {
    "Issuer": "http://localhost:5000",
    "Audience": "kyvo-api",
    "RefreshTokenDays": 30,
    "SigningKeyPath": "keys/oidc-signing.pem",
    "SigningKeyPem": "",
    "KeyId": "dev-2026"
  },

  "Bootstrap": {
    "AdminEmail": "admin@localhost",
    "AdminPassword": "admin@localhost",
    "AdminDisplayName": "Admin"
  },

  "RateLimit": {
    "BootstrapPermitLimit": 3,
    "BootstrapWindowMinutes": 15,
    "AccountRegisterPermitLimit": 5,
    "AccountRegisterWindowMinutes": 15
  },

  "Invite": {
    "ExpirationHours": 72
  },

  "Email": {
    "FromAddress": "noreply@localhost",
    "Region": "us-east-1",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "SessionToken": ""
  },

  "Redis": {
    "ConnectionString": "localhost:6379,password=default_password",
    "InstanceName": "kyvo:",
    "TenantIdentifierCacheMinutes": 5
  },

  "SecretProtection": {
    "KeyDirectoryPath": "keys/data-protection",
    "ApplicationName": "Kyvo"
  },

  "PasswordPolicy": {
    "MinLength": 12,
    "RequireDigit": true,
    "RequireLetter": true
  }
}
