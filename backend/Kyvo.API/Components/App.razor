<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#0a0a0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f7fb" media="(prefers-color-scheme: light)" />
    <base href="/" />
    <link rel="icon" type="image/png" href="/brand/kyvo-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        (function () {
            var key = 'kyvo-account-theme';
            var theme;
            try { theme = localStorage.getItem(key); } catch (e) { }
            if (theme !== 'light' && theme !== 'dark') {
                theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            document.documentElement.setAttribute('data-theme', theme);
            document.documentElement.style.colorScheme = theme;
        })();
    </script>
    <link rel="stylesheet" href="css/account.css" />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <script src="js/account-theme.js"></script>
</body>
</html>
