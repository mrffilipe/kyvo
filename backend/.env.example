# Kyvo API — Docker Compose (.env)
#
#   cp .env.example .env
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out keys/oidc-signing.pem
#   docker compose up -d
#
# PostgreSQL and Redis are not part of this compose file — run them on the host (or elsewhere)
# and point the connection strings below at host.docker.internal (reachable from inside the container).

# --- Compose ---
API_PORT=5000
JWT_SIGNING_KEY_HOST_PATH=./keys/oidc-signing.pem

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080
ASPNETCORE_URLS=http://+:8080

# --- Database (required) ---
Database__ConnectionString=Host=host.docker.internal;Port=5432;Database=kyvo_db;Username=postgres;Password=postgrespassword

# --- JWT / OIDC (required — configure exactly one signing key source) ---
# Issuer must match the URL browsers use to reach the API (host port mapped above).
Jwt__Issuer=http://localhost:5000
Jwt__Audience=kyvo-api
Jwt__KeyId=dev-2026
Jwt__RefreshTokenDays=30
Jwt__SigningKeyPath=keys/oidc-signing.pem
Jwt__SigningKeyPem=
Jwt__SigningKeyPemBase64=

# --- Redis (optional — leave ConnectionString empty for in-memory cache) ---
Redis__ConnectionString=host.docker.internal:6379,password=default_password,ssl=false
Redis__InstanceName=kyvo:
Redis__TenantIdentifierCacheMinutes=5

# --- Data Protection ---
SecretProtection__KeyDirectoryPath=keys/data-protection
SecretProtection__ApplicationName=Kyvo

# --- Bootstrap (first run — remove from .env after successful login) ---
Bootstrap__AdminEmail=admin@localhost
Bootstrap__AdminPassword=admin@localhost
Bootstrap__AdminDisplayName=Platform Admin

# --- Email (AWS SES — optional in local dev) ---
Email__FromAddress=noreply@localhost
Email__Region=us-east-1
Email__AccessKeyId=
Email__SecretAccessKey=
Email__SessionToken=
