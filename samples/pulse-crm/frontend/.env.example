# All variables below are optional in local development; the values shown here are also the
# built-in defaults loaded by src/config/env.ts when the variable is missing or empty.

# Kyvo from source (dotnet run): https://localhost:5101 — Docker/nginx: https://localhost:8443
VITE_KYVO_AUTHORITY=https://localhost:5101
VITE_KYVO_CLIENT_ID=pulse-crm-web
VITE_KYVO_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_KYVO_SCOPES=openid profile email offline_access
VITE_CRM_API_URL=http://localhost:5100
